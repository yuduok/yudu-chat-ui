PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# Agent workspace tools. Relative paths are confined to this root.
YUDU_WORKSPACE_ROOT=/absolute/path/to/your/workspace

# High-risk tools are disabled unless explicitly enabled. execute_command also
# requires a comma-separated executable allowlist; use * only for unrestricted
# execution in an already isolated environment.
YUDU_ENABLE_WRITE_TOOL=false
YUDU_ENABLE_COMMAND_TOOL=false
YUDU_COMMAND_ALLOW=git,rg,pnpm

# Enables the web_search tool when set.
YUDU_TAVILY_API_KEY=
